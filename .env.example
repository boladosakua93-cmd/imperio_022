# Copia este arquivo para .env e preencha os valores

# Banco de dados MySQL (para a plataforma web)
DATABASE_URL=mysql://usuario:senha@host:3306/imperio_022

# Segredos de sessão
SESSION_SECRET=troque-por-um-valor-aleatorio-seguro

# OAuth (se usar autenticação social na web)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# ID do dono/admin (openId retornado pelo OAuth)
OWNER_OPEN_ID=
